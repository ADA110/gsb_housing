# ─── gsbhouse local dev ───

# OPTIONAL: Add a Resend API key to send real emails.
# Without this, verification codes print to your terminal.
# RESEND_API_KEY=re_xxxxxxxxxx
# EMAIL_FROM=gsbhouse <onboarding@resend.dev>

# REQUIRED for admin panel: set a strong secret, then visit /?admin
# ADMIN_SECRET=your-secret-here

# Server port (default 3001)
# PORT=3001
